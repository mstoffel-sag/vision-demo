# Copy to .env and adjust:  cp .env.example .env
#
# thin-edge.io is expected to run on the host. The container reaches its MQTT
# broker (1883) and Cumulocity HTTP proxy (8001) over localhost (host
# networking), and uses the host's /etc/tedge (bind-mounted read-only in
# docker-compose.yml) for the device certificate. Point mqtt_host/mqtt_port in
# pipeline/config/pipeline.json at the broker (localhost:1883 by default).

# ── Optris Thermal Camera SDK (downloaded at build time) ─────────────────────
# See github.com/Optris/otcsdk_downloads/releases for available versions.
OTCSDK_VERSION=11.3.0
OTCSDK_UBUNTU=24.04
